#!/usr/bin/env bash
# xnotify — backward-compatible alias for `notify`.
#
# The cross-platform notification logic now lives in `notify` (same directory).
# This shim is kept so existing callers referencing `xnotify` keep working.
# Prefer calling `notify` directly in new code.

set -u

# Resolve `notify` next to this script first, then fall back to PATH.
_here="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -x "$_here/notify" ]]; then
    exec "$_here/notify" "$@"
elif command -v notify >/dev/null 2>&1; then
    exec notify "$@"
fi

# No notifier available — no-op so callers (e.g. shell hooks) never fail.
exit 0
